# Optional: SMTP for sending OTP emails. If not set, OTP is printed to terminal.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@example.com

# Optional: Auction start time (ISO format). If not set, auction starts immediately on first run.
# AUCTION_START_TIME=2025-03-15T20:00:00

# Optional: Secret for session tokens (random string). If not set, a default is used (dev only).
# SECRET_KEY=your-random-secret-key

# Database path (defaults to ./auction.db if not set)
# DATABASE_URL=sqlite:///./auction.db
